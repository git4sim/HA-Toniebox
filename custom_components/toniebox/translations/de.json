      }
    },
    "move_chapter": {
      "name": "Kapitel verschieben",
      "description": "Ein Kapitel eine Position nach oben oder unten verschieben.",
      "fields": {
        "entity_id": { "name": "Kreativ-Tonie", "description": "Die media_player-Entität des Ziel-Kreativ-Tonies." },
