      "unknown": "Ein unbekannter Fehler ist aufgetreten."
    },
    "abort": {
      "already_configured": "Dieses Toniebox-Konto ist bereits eingerichtet.",
      "reauth_successful": "Die erneute Anmeldung war erfolgreich."
    }
