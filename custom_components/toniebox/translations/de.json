        "direction": { "name": "Richtung", "description": "'up' verschiebt nach vorne, 'down' nach hinten in der Liste." }
      }
    },
    "upload_audio": {
      "name": "Audio hochladen",
      "description": "Eine lokale Audiodatei als neues Kapitel auf einen Kreativ-Tonie hochladen. Unterstützte Formate: mp3, ogg, wav, flac, m4a, aac, opus.",
      "fields": {
        "entity_id": { "name": "Kreativ-Tonie", "description": "Die media_player-Entität des Ziel-Kreativ-Tonies." },
        "file_path": { "name": "Dateipfad", "description": "Absoluter Pfad zur Audiodatei auf dem HA-Host (z. B. /config/tonie_audio/geschichte.mp3)." },
        "title": { "name": "Kapiteltitel", "description": "Titel des Kapitels. Standardmäßig wird der Dateiname ohne Erweiterung verwendet." }
      }
    },
    "rename_tonie": {
      "name": "Tonie umbenennen",
      "description": "Einen Kreativ-Tonie umbenennen.",
      "fields": {
        "entity_id": { "name": "Kreativ-Tonie", "description": "Die media_player-Entität des Ziel-Kreativ-Tonies." },
        "name": { "name": "Neuer Name", "description": "Der neue Name des Tonies." }
      }
    },
    "rename_toniebox": {
      "name": "Toniebox umbenennen",
      "description": "Eine Toniebox umbenennen.",
      "fields": {
        "entity_id": { "name": "Toniebox", "description": "Die media_player-Entität der Toniebox." },
        "name": { "name": "Neuer Name", "description": "Der neue Name der Toniebox." }
      }
    },
    "redeem_content_token": {
      "name": "Inhalts-Token einlösen",
      "description": "Einen kostenlosen Inhalts-Token auf einen Kreativ-Tonie einlösen.",
      "fields": {
        "entity_id": { "name": "Kreativ-Tonie", "description": "Die media_player-Entität des Ziel-Kreativ-Tonies." },
