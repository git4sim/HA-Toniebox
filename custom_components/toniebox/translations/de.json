{
  "config": {
    "step": {
      "user": {
        "title": "Toniebox Cloud Anmeldung",
        "description": "Gib deine Toniebox / Boxine-Zugangsdaten ein.\nDeine Daten werden ausschließlich für die Kommunikation mit der offiziellen Toniebox Cloud (api.tonie.cloud) verwendet.",
        "data": {
          "username": "E-Mail-Adresse",
          "password": "Passwort"
        }
      },
      "reauth_confirm": {
        "title": "Erneute Anmeldung bei Toniebox",
        "description": "Deine Sitzung ist abgelaufen. Bitte gib deine Zugangsdaten erneut ein.",
