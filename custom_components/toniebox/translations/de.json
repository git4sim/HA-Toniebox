        "entity_id": { "name": "Tonie", "description": "Die Tonie-Entität." },
        "tune_id": { "name": "Tune-ID", "description": "Die ID des anzuwendenden Tunes." }
      }
    },
    "remove_tune": {
      "name": "Tune entfernen",
      "description": "Den aktiven Tune eines Tonies entfernen (stellt den Originalinhalt wieder her).",
      "fields": {
        "entity_id": { "name": "Tonie", "description": "Die Tonie-Entität." }
      }
    },
    "redeem_voucher": {
      "name": "Gutschein einlösen",
      "description": "Einen Tunes-Gutscheincode einlösen.",
      "fields": {
        "code": { "name": "Gutscheincode", "description": "Der einzulösende Gutscheincode." }
      }
